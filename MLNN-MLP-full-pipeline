import torch
import torch.nn as nn
import torch.optim as optim
import numpy as np

# ----------------------------------------------------------------
# Predicate / branch index maps
# ----------------------------------------------------------------
PREDICATE_NAMES = [
    'DistanceToPedestrian',    # 0
    'TimeToCollision',         # 1
    'PedestrianInCrosswalk',   # 2
    'EgoInCrosswalk',          # 3
    'Collision',               # 4
    'EgoBraking',              # 5
    'EgoAccelerating',         # 6
    'EgoStopped',              # 7
    'PedestrianIntentToCross', # 8
]
BRANCH_NAMES = ['brake', 'coast', 'accel']

# ----------------------------------------------------------------
# Fuzzy logic primitives
# ----------------------------------------------------------------
def fuzzy_sigmoid(x, beta=10):
    """Map real-valued predicates to [0,1] fuzzy truth values.
    Beta=10 chosen empirically; values above ~20 approach thresholding, and
       were found to destabilize training in preliminary runs.
    Note: continuous predicates (Dist, TTC) benefit from normalisation
    before this mapping (as discussed in paper) — see normalise_tensor() below.
    """
    return torch.sigmoid(beta * (2 * x - 1))

def normalise_tensor(data):
    """Min-max normalise each predicate channel independently
    so that continuous predictates (Dist, TTC) map to [0,1]
    before fuzzy_sigmoid is applied.
    data: (E, B, T, P)
    """
    out = data.clone()
    for p in range(data.shape[-1]):
        mn = data[..., p].min()
        mx = data[..., p].max()
        if mx - mn > 1e-6:
            out[..., p] = (data[..., p] - mn) / (mx - mn)
    return out

def implication(a, b):
    """Lukasiewicz fuzzy implication: min(1, 1-a+b).
    Equivalent to 'if a then b' in [0,1] truth space.
    """
    return torch.clamp(1.0 - a + b, 0.0, 1.0)

# ----------------------------------------------------------------
# Temporal operators  — act over tick dimension (dim=2)
# Note that the templates function implicitly over time (ticks),
#   so they have been given an implicit "F" operator to signify
#   "eventually".  This can be understood as a temporal equivalent
#   of "possibly."
# Postscript: This is not explicitly discussed in the paper.
# ----------------------------------------------------------------
def eventually(x):
    """F phi — True at some future tick.  Max over time (dim=2).
    x: (..., T, ...) -> (..., ...)
    """
    return torch.max(x, dim=2).values

def always(x):
    """G phi — True at all future ticks.  Min over time (dim=2)."""
    return torch.min(x, dim=2).values

# ----------------------------------------------------------------
# Modal operators  — act over branch dimension (dim=1)
# ----------------------------------------------------------------
def possibly(x):
    """◊ phi — True in at least one accessible world (branch).
    Max over branches (dim=1).
    """
    return torch.max(x, dim=1).values

def necessarily(x):
    """□ phi — True in ALL accessible worlds (branches).
    Min over branches (dim=1).
    """
    return torch.min(x, dim=1).values

