# ================================================================
# MLP Baseline Comparison — Three Topologies
# ================================================================
#
# The script:
#   1. Assembles the shared formula targets (same block as MLNN training)
#   2. Builds the three MLP input tensors
#   3. Trains all three topologies
#   4. Collects MLNN final correlations from `history`
#   5. Prints a unified results table
#   6. Plots all four systems on one figure
# ================================================================

import torch
import torch.optim as optim
import numpy as np
import matplotlib.pyplot as plt

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

# ── 1. Shared preprocessing ──────────────────────────────────────
raw = torch.tensor(mlnn_tensor, dtype=torch.float32).to(device)
raw = normalise_tensor(raw)
T   = fuzzy_sigmoid(raw)                        # (E, B, Nt, P)
E   = T.shape[0]

IDX = {name: i for i, name in enumerate(PREDICATE_NAMES)}
antecedent_threshold = 0.3

def pm(idx, top=eventually, mop=necessarily):
    """Convenience wrapper: same signature as pred_modal in train cell."""
    p = T[..., idx]
    p = top(p.unsqueeze(-1)).squeeze(-1)
    p = mop(p.unsqueeze(-1)).squeeze(-1)
    return p

# ── 2. Shared formula targets (identical to MLNN training cell) ──
with torch.no_grad():
    col     = pm(IDX["Collision"],              eventually, possibly)
    accel   = pm(IDX["EgoAccelerating"],        eventually, possibly)
    ped_x   = pm(IDX["PedestrianInCrosswalk"], eventually, necessarily)
    ttc_low = pm(IDX["TimeToCollision"],
                 lambda x: always(1.0 - x),    necessarily)
    stopped = pm(IDX["EgoStopped"],            eventually, possibly)

    # Remaining four for the 9-dim modal input vector
    intent  = pm(IDX["PedestrianIntentToCross"], eventually, necessarily)
    brake   = pm(IDX["EgoBraking"],              eventually, possibly)
    dist    = pm(IDX["DistanceToPedestrian"],    eventually, necessarily)
    ego_x   = pm(IDX["EgoInCrosswalk"],         eventually, necessarily)

    f2_tgt  = implication(col,           1.0 - accel).detach()
    f3_tgt  = implication(ped_x*ttc_low, stopped).detach()
    f2_mask = (col           > antecedent_threshold).float().detach()
    f3_mask = (ped_x*ttc_low > antecedent_threshold).float().detach()

    print(f"F2: mean={f2_tgt.mean():.4f}  std={f2_tgt.std():.4f}"
          f"  active={f2_mask.mean():.3f}")
    print(f"F3: mean={f3_tgt.mean():.4f}  std={f3_tgt.std():.4f}"
          f"  active={f3_mask.mean():.3f}")

# ── 3. Three MLP input tensors, two topologies ───────────────────────────────────

# Topology 1: episode-level 9-dim modal projection vector
X_modal = torch.stack(
    [dist, ttc_low, ped_x, ego_x, col,
     brake, accel, stopped, intent], dim=1
).detach()                                      # (E, 9)

# Topology 2: full flattened tensor — (E, B*T*P) = (E, 810)
X_flat = T.view(E, -1).detach()                # (E, 810)

print(f"\nX_modal shape : {X_modal.shape}")
print(f"X_flat  shape : {X_flat.shape}")

# ── 4. Run all three topologies ──────────────────────────────────
EPOCHS      = 300
LR          = 3e-3
PRINT_EVERY = 60

configs = [
    dict(name="MLP-A  (H=8,   modal)",
         input=X_modal, hidden_size=8),
    dict(name="MLP-B  (H=810, modal)",
         input=X_modal,  hidden_size=810),
    dict(name="MLP-C  (H=32,  flat)",
         input=X_flat, hidden_size=32),
]

mlp_histories = {}

for cfg in configs:
    print(f"\n{'='*60}")
    print(f"Training {cfg['name']}")
    print(f"{'='*60}")

    input_size = cfg["input"].shape[1]    #05/27/2026: 9 for modal, 810 for flat

    mlp = MLP(
        input_size = input_size,
        hidden_size = cfg["hidden_size"],
        output_size = 2
    ).to(device)

    hist = mlp.train_MLP(
        X         = cfg["input"].to(device),
        f2_tgt    = f2_tgt,
        f3_tgt    = f3_tgt,
        f2_mask   = f2_mask,
        f3_mask   = f3_mask,
        epochs    = EPOCHS,
        learning_rate = LR,
        print_every   = PRINT_EVERY,
    )

    mlp_histories[cfg["name"]] = hist

# ── 5. Retrieve MLNN final correlations from existing history ────
# `history` is the list produced by train_mlnn() earlier in the notebook
mlnn_f2_final = history[-1]["f2_corr"]
mlnn_f3_final = history[-1]["f3_corr"]

# ── 6. Results table ─────────────────────────────────────────────
print(f"\n{'='*60}")
print(f"{'Model':<28} {'F2 r':>8} {'F3 r':>8}")
print(f"{'-'*44}")
print(f"{'MLNN (modal + logical)':<28} {mlnn_f2_final:>8.4f} {mlnn_f3_final:>8.4f}")
for name, hist in mlp_histories.items():
    f2 = hist[-1]["f2_corr"]
    f3 = hist[-1]["f3_corr"]
    print(f"{name:<28} {f2:>8.4f} {f3:>8.4f}")
print(f"{'='*60}")
print(f"Antecedent activation:  F2={f2_mask.mean():.3f}  F3={f3_mask.mean():.3f}")
print(f"Chance baseline r ≈ 0.00 (random predictor on masked episodes)")

# ── 7. Plot — correlation curves for all four systems ───────────
fig, axes = plt.subplots(1, 2, figsize=(14, 5))
titles    = ["F2 correlation  (Collision→¬Accel)",
             "F3 correlation  (PedInX∧LowTTC→Stop)"]
keys      = ["f2_corr", "f3_corr"]
colors    = {
    "MLNN":   ("#0F6E56", "-",  2.0),
    "MLP-A":  ("#534AB7", "--", 1.2),
    "MLP-B":  ("#993C1D", ":",  1.2),
    "MLP-C":  ("#854F0B", "-.", 1.2),
}

for ax, title, key in zip(axes, titles, keys):
    # MLNN
    epochs_mlnn = [h["epoch"] for h in history]
    vals_mlnn   = [h[key]     for h in history]
    ax.plot(epochs_mlnn, vals_mlnn,
            color=colors["MLNN"][0],
            linestyle=colors["MLNN"][1],
            linewidth=colors["MLNN"][2],
            label="MLNN (modal + logical)")

    # MLP topologies
    mlp_labels = {
        "MLP-A  (H=8,   modal)": "MLP-A",
        "MLP-B  (H=810, modal)":  "MLP-B",
        "MLP-C  (H=32,  flat)": "MLP-C",
    }
    for full_name, short in mlp_labels.items():
        hist = mlp_histories[full_name]
        epochs_mlp = [h["epoch"] for h in hist]
        vals_mlp   = [h[key]     for h in hist]
        c, ls, lw  = colors[short]
        ax.plot(epochs_mlp, vals_mlp,
                color=c, linestyle=ls, linewidth=lw,
                label=full_name.strip())

    ax.axhline(0.5, color="green", linestyle="--",
               linewidth=0.8, alpha=0.5, label="Target r=0.5")
    ax.axhline(0.0, color="gray",  linestyle=":",
               linewidth=0.6)
    ax.set_title(title, fontsize=12)
    ax.set_xlabel("Epoch")
    ax.set_ylabel("Pearson r")
    ax.set_ylim(-0.1, 1.05)
    ax.legend(fontsize=8)
    ax.grid(True, alpha=0.3)

plt.suptitle(
    "MLNN vs MLP baselines — head prediction correlation\n"
    "(same formula targets, same masked BCE loss, same epochs)",
    fontsize=11
)
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, "mlnn_mlp_comparison.png"), dpi=150, bbox_inches="tight")
plt.show()
print("Saved: /content/mlnn_mlp_comparison.png")

