# ----------------------------------------------------------------
# MLNN Model  (version F — with formula prediction head)
# ----------------------------------------------------------------
class MLNN(nn.Module):
    """
    Modal Logical Neural Network with formula prediction head.

    Architecture:
      1. clause_layer:  weighted-mean t-norm over predicates -> (E,B,T,C)
      2. eventually:    max over ticks                       -> (E,B,C)
      3. necessarily:   min over branches                    -> (E,C)
      4. formula_head:  linear map C -> n_formulas           -> (E,F)
         maps clause features to formula satisfaction scores

    The head solves the scale mismatch: clauses live in [0.1,0.2]
    but formula targets live in [0.7,0.9].  The head learns the
    affine mapping; clause weights learn to discriminate episodes.
    """

    def __init__(self, n_predicates, n_clauses, n_formulas=2):
        super().__init__()
        self.n_pred     = n_predicates
        self.n_clauses  = n_clauses
        self.n_formulas = n_formulas

        # Clause weights: sigmoid maps to participation in [0,1]
        self.clause_weights = nn.Parameter(
            torch.zeros(n_clauses, n_predicates)
            + torch.randn(n_clauses, n_predicates) * 0.5
        )

        # Formula head: linear mapping from clause features to formula scores
        # Initialized to spread output toward [0,1] target range
        self.formula_head = nn.Linear(n_clauses, n_formulas, bias=True)
        nn.init.xavier_uniform_(self.formula_head.weight)
        nn.init.constant_(self.formula_head.bias, 0.5)

    def clause_layer(self, T):
        """
        T   : (E, B, T, P)
        out : (E, B, T, C)
        """
        W     = torch.sigmoid(self.clause_weights)        # (C, P)
        W     = W.view(1, 1, 1, self.n_clauses, self.n_pred)
        T_exp = T.unsqueeze(-2)                           # (E, B, T, 1, P)
        weighted     = W * T_exp                          # (E, B, T, C, P)
        clause_vals  = torch.mean(weighted, dim=-1)       # (E, B, T, C)
        return clause_vals

    def forward(self, T):
        """
        T : (E, B, T, P)
        Returns:
            f_pred  : (E, F)  formula satisfaction predictions in [0,1]
            C_nec   : (E, C)  clause features after modal lifting
            C_temp  : (E, B, C)
        """
        C       = self.clause_layer(T)         # (E, B, T, C)
        C_temp  = eventually(C)                # (E, B, C)
        C_nec   = necessarily(C_temp)          # (E, C)
        C_poss  = possibly(C_temp)             # (E, C)

        # Formula head maps clause features to satisfaction scores
        f_pred  = torch.sigmoid(self.formula_head(C_nec))  # (E, F)

        return f_pred, C_nec, C_temp

