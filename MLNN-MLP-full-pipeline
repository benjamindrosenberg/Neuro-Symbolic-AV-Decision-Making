# [SIM] Kinematic crosswalk simulator
# Writes the same dataset structure as the CARLA version.
import numpy as np, csv, json, math, random
from pathlib import Path

# ----------------------------------------------------------------
# Constants (identical to CARLA version)
# ----------------------------------------------------------------
TICK          = 0.05          # seconds per tick
EP_TICKS      = 60            # factual trace length
BR_TICKS      = 30            # branch rollout length
INT_RADIUS    = 20.0          # episode trigger radius (m)
DISENG_RADIUS = 40.0          # episode end radius (m)
N_EPISODES    = 5_000

BRAKE_LO, BRAKE_HI   = 0.4, 1.0
THROT_LO, THROT_HI   = 0.2, 0.7
COAST_LO, COAST_HI   = 1,   3
EGO_SPD_LO            = 4.0
EGO_SPD_HI            = 13.9

PED_SPEED_BANDS = {
    'slow':   (0.8,  1.2),
    'medium': (1.2,  1.8),
    'fast':   (1.8,  2.5),
}
CW_WIDTH_CATS = {
    'urban':    (2.0,  3.9),
    'standard': (4.0,  7.9),
    'wide':     (8.0, 12.0),
}
PED_CATS = ['legal', 'edge', 'jaywalking']
WEATHERS = [
    'ClearNoon', 'CloudyNoon', 'WetNoon', 'HardRainNoon',
    'ClearSunset', 'CloudySunset', 'WetSunset', 'HardRainSunset',
    'ClearNight', 'FogNoon',
]

PRED_HEADERS = [
    'DistanceToPedestrian', 'TimeToCollision',
    'PedestrianInCrosswalk', 'EgoInCrosswalk',
    'Collision', 'EgoBraking', 'EgoAccelerating',
    'EgoStopped', 'PedestrianIntentToCross',
]
BRANCH_HEADERS = [
    'time_index', 'timestamp',
    'Dist', 'TTC',
    'PedInX', 'EgoInX', 'Collision',
    'Brake', 'Accel', 'Stopped', 'PedIntent',
]
RAW_HEADERS = [
    'time_index', 'timestamp',
    'ego_speed', 'ped_speed',
    'ego_x', 'ego_y', 'ped_x', 'ped_y',
]
REQUIRED = {
    'metadata.json', 'factual_trace.csv',
    'branch_brake.csv', 'branch_coast.csv',
    'branch_accel.csv', 'raw_observables.csv',
}

# ----------------------------------------------------------------
# Crosswalk geometry
# A crosswalk is modeled as an axis-aligned rectangle centered at
# (cx, cy).  The Ego travels along the x-axis; the pedestrian
# crosses perpendicular (along y).
# ----------------------------------------------------------------
def make_crosswalk(cw_width, rng):
    """Return a crosswalk dict with geometry and a spawn waypoint."""
    # Place crosswalk center at a canonical location;
    # Slight random offset keeps episodes visually distinct.
    cx = rng.uniform(12.0, 22.0)   # closer crosswalk -> collisions possible
    cy = 0.0
    half_w = cw_width / 2.0
    half_d = 2.0                   # crosswalk depth along Ego travel axis
    poly = [
        (cx - half_d, cy - half_w),
        (cx + half_d, cy - half_w),
        (cx + half_d, cy + half_w),
        (cx - half_d, cy + half_w),
    ]
    return {'cx': cx, 'cy': cy, 'cw_width': cw_width,
            'half_d': half_d, 'poly': poly}

def point_in_rect(px, py, poly):
    """Ray-cast point-in-polygon (works for any convex polygon)."""
    n, inside = len(poly), False
    j = n - 1
    for i in range(n):
        xi, yi = poly[i]
        xj, yj = poly[j]
        if ((yi > py) != (yj > py)) and \
           (px < (xj - xi) * (py - yi) / (yj - yi + 1e-9) + xi):
            inside = not inside
        j = i
    return inside

def cw_width_cat(w):
    for name, (lo, hi) in CW_WIDTH_CATS.items():
        if lo <= w <= hi:
            return name
    return 'other'

# ----------------------------------------------------------------
# Kinematic state
# ----------------------------------------------------------------
class EgoState:
    """Ego vehicle travelling along the x-axis."""
    __slots__ = ('x', 'y', 'vx', 'vy', 'ax',
                 'brake', 'throttle',
                 'max_decel', 'max_accel')

    def __init__(self, x, speed):
        self.x  = x;  self.y  = 0.0
        self.vx = speed; self.vy = 0.0
        self.ax = 0.0
        self.brake    = 0.0
        self.throttle = 0.0
        self.max_decel = 8.0   # m/s^2  (comfortable hard brake?)
        self.max_accel = 3.0   # m/s^2

    def step(self, dt):
        # Net acceleration from control inputs
        self.ax = (self.throttle * self.max_accel
                   - self.brake  * self.max_decel)
        self.vx = max(0.0, self.vx + self.ax * dt)
        self.x += self.vx * dt

    @property
    def speed(self):
        return abs(self.vx)


class PedState:
    """Pedestrian travelling along the y-axis (crossing the road)."""
    __slots__ = ('x', 'y', 'vy', 'target_y',
                 'speed', 'accel_phase', 'elapsed')

    def __init__(self, x, y, target_y, speed, accel_phase):
        self.x          = x
        self.y          = y
        self.target_y   = target_y
        self.speed      = speed
        self.accel_phase = accel_phase  # distance over which ped accelerates
        self.elapsed    = 0.0
        # Direction of travel
        self.vy = speed if target_y > y else -speed

    def step(self, dt):
        # Simple linear motion; acceleration phase ramps up from 0
        dist_moved = abs(self.y - (self.target_y - self.vy * 999))
        ramp = min(1.0, self.elapsed / max(self.accel_phase, 0.01))
        vy_actual = self.vy * ramp
        self.y       += vy_actual * dt
        self.elapsed += dt
        # Clamp at target
        if self.vy > 0 and self.y >= self.target_y:
            self.y = self.target_y
        elif self.vy < 0 and self.y <= self.target_y:
            self.y = self.target_y

    @property
    def current_vy(self):
        ramp = min(1.0, self.elapsed / max(self.accel_phase, 0.01))
        return self.vy * ramp

    @property
    def reached_target(self):
        return abs(self.y - self.target_y) < 0.05

# ----------------------------------------------------------------
# Predicate evaluation
# ----------------------------------------------------------------
def dist2d(ax, ay, bx, by):
    return math.sqrt((ax - bx)**2 + (ay - by)**2)

def compute_ttc(ego, ped):
    """Closing-speed TTC along line of sight."""
    d = dist2d(ego.x, ego.y, ped.x, ped.y)
    if d < 0.1:
        return 0.0
    dx = (ped.x - ego.x) / d
    dy = (ped.y - ego.y) / d
    closing = ego.vx * dx - ped.current_vy * dy
    return d / closing if closing > 0 else 999.0

def ped_intent(ped, cx, cy):
    """True when ped heading has component toward crosswalk center."""
    vy = ped.current_vy
    if abs(vy) < 0.05:
        return False
    dy = cy - ped.y
    d  = abs(dy) + 1e-9
    dot = vy * dy / (abs(vy) * d)
    return dot > 0.3

def collision_check(ego, ped):
    """Simple bounding-box collision: ego 4x2 m, ped 0.5x0.5 m."""
    return (abs(ego.x - ped.x) < 2.25 and
            abs(ego.y - ped.y) < 1.25)

def eval_predicates(ego, ped, cw, collision):
    d   = dist2d(ego.x, ego.y, ped.x, ped.y)
    ttc = compute_ttc(ego, ped)
    return {
        'DistanceToPedestrian':    round(d,   4),
        'TimeToCollision':         round(ttc, 4),
        'PedestrianInCrosswalk':   point_in_rect(ped.x, ped.y, cw['poly']),
        'EgoInCrosswalk':          point_in_rect(ego.x, ego.y, cw['poly']),
        'Collision':               collision,
        'EgoBraking':              ego.brake    > 0.05,
        'EgoAccelerating':         ego.throttle > 0.05 and ego.brake <= 0.05,
        'EgoStopped':              ego.speed    < 0.1,
        'PedestrianIntentToCross': ped_intent(ped, cw['cx'], cw['cy']),
    }

def to_branch_row(t, pv):
    return {
        'time_index': t,
        'timestamp':  round(t * TICK, 4),
        'Dist':       pv['DistanceToPedestrian'],
        'TTC':        pv['TimeToCollision'],
        'PedInX':     int(pv['PedestrianInCrosswalk']),
        'EgoInX':     int(pv['EgoInCrosswalk']),
        'Collision':  int(pv['Collision']),
        'Brake':      int(pv['EgoBraking']),
        'Accel':      int(pv['EgoAccelerating']),
        'Stopped':    int(pv['EgoStopped']),
        'PedIntent':  int(pv['PedestrianIntentToCross']),
    }

# ----------------------------------------------------------------
# IO helpers
# ----------------------------------------------------------------
def write_csv(path, headers, rows):
    with open(path, 'w', newline='') as f:
        w = csv.DictWriter(f, fieldnames=headers)
        w.writeheader()
        w.writerows(rows)

def ep_done(d):
    return all(
        (d / fn).exists() and (d / fn).stat().st_size > 0
        for fn in REQUIRED
    )

# ----------------------------------------------------------------
# Branch rollout
# ----------------------------------------------------------------
def run_branch(ego_x0, ego_vx0, ped_x0, ped_y0, ped_vy,
               ped_speed, ped_accel, cw, btype, branch_t0, rng):
    """Rollout one counterfactual branch for BR_TICKS ticks."""
    # Sample branch parameters
    if btype == 'brake':
        bs = rng.uniform(BRAKE_LO, BRAKE_HI)
        tl, ct = 0.0, 0
    elif btype == 'coast':
        bs, tl = 0.0, 0.0
        ct = rng.randint(COAST_LO, COAST_HI + 1)
    else:
        tl = rng.uniform(THROT_LO, THROT_HI)
        bs, ct = 0.0, 0
    params = {'brake_strength': bs,
              'throttle_level': tl,
              'coast_ticks':    ct}

    # Reconstruct states at fork point
    ego = EgoState(ego_x0, ego_vx0)
    ped = PedState(ped_x0, ped_y0,
                   target_y = cw['cy'] + cw['cw_width'],
                   speed    = ped_speed,
                   accel_phase = ped_accel)
    ped.vy = ped_vy

    rows, col = [], False
    last_pv   = None

    for bt in range(BR_TICKS):
        # Apply branch control
        if btype == 'brake':
            ego.brake = bs; ego.throttle = 0.0
        elif btype == 'coast':
            ego.brake = 0.0
            ego.throttle = 0.0 if bt < ct else 0.0
        else:
            ego.throttle = tl; ego.brake = 0.0

        ego.step(TICK)
        ped.step(TICK)

        if not col:
            col = collision_check(ego, ped)
        pv = eval_predicates(ego, ped, cw, col)
        rows.append(to_branch_row(branch_t0 + bt, pv))
        last_pv = pv

        # Early exit on disengagement — pad remaining rows
        if dist2d(ego.x, ego.y, ped.x, ped.y) > DISENG_RADIUS:
            for bt2 in range(bt + 1, BR_TICKS):
                rows.append(to_branch_row(branch_t0 + bt2, last_pv))
            break

    # Pad to BR_TICKS if loop ended early for another reason
    while len(rows) < BR_TICKS:
        rows.append(to_branch_row(branch_t0 + len(rows), last_pv))

    return rows, params

# ----------------------------------------------------------------
# Episode runner
# ----------------------------------------------------------------
def run_episode(ep_id, ep_dir, rng):
    # ---- Sample configuration --------------------------------------
    ped_cat   = rng.choice(PED_CATS)
    spd_band  = rng.choice(list(PED_SPEED_BANDS))
    lo, hi    = PED_SPEED_BANDS[spd_band]
    ped_speed = rng.uniform(lo, hi)
    entry     = rng.choice(['left', 'right'])
    cw_width  = rng.uniform(2.0, 12.0)
    offset    = rng.uniform(-cw_width * 0.4, cw_width * 0.4)
    accel_ph  = rng.uniform(0.5, 2.0)
    ego_spd0  = rng.uniform(EGO_SPD_LO, EGO_SPD_HI)
    spawn_d   = rng.uniform(12.0, 30.0)
    weather   = rng.choice(WEATHERS)

    cw = make_crosswalk(cw_width, rng)

    # ---- Spawn positions -------------------------------------------
    ego_x0 = cw['cx'] - spawn_d

    # Pedestrian starts outside the crosswalk, walks across it
    if ped_cat == 'legal':
        ped_y0    = cw['cy'] - (cw_width / 2 + 0.5) + offset
        ped_tgt_y = cw['cy'] + (cw_width / 2 + 0.5)
    elif ped_cat == 'edge':
        ped_y0    = cw['cy'] - (cw_width / 2 - 0.3) + offset
        ped_tgt_y = cw['cy'] + (cw_width / 2 + 1.0)
    else:  # jaywalking
        jw = rng.uniform(5.0, 12.0) * rng.choice([-1, 1])
        ped_y0    = cw['cy'] + jw + offset
        ped_tgt_y = cw['cy'] - jw

    ped_x0 = cw['cx'] + offset * 0.5

    # ---- Initialise states -----------------------------------------
    ego = EgoState(ego_x0, ego_spd0)
    ped = PedState(ped_x0, ped_y0, ped_tgt_y, ped_speed, accel_ph)
    ped_spawn_y  = ped_y0
    ped_spawn_x  = ped_x0
    ped_spawn_vy = ped.vy

    # ---- Wait for trigger (max 400 ticks) --------------------------
    triggered    = False
    for _ in range(400):
        ego.step(TICK)
        ped.step(TICK)
        d = dist2d(ego.x, ego.y, ped.x, ped.y)
        if d < INT_RADIUS and ped_intent(ped, cw['cx'], cw['cy']):
            triggered = True
            break
        # Give up if ego has passed the crosswalk
        if ego.x > cw['cx'] + 20.0:
            break

    if not triggered:
        return False

    # ---- Factual trace ---------------------------------------------
    # Ego uses a simple reactive policy: brake if TTC < 3 s and
    # ped is in or approaching crosswalk, else maintain speed.
    factual_rows, raw_rows = [], []
    branch_t_idx = -1
    col = False

    # Save ego state at fork for branch reset
    fork_ego_x = ego.x
    fork_ego_vx = ego.vx
    fork_ped_x  = ped.x
    fork_ped_y  = ped.y
    fork_ped_vy = ped.vy

    # Sample ego policy type for this episode:
    #   'cautious'   (60%) — brakes reliably when ped present
    #   'late'       (20%) — brakes but with a reaction delay
    #   'aggressive' (20%) — maintains speed, may collide
    policy = rng.choices(
        ['cautious', 'late', 'aggressive'],
        weights=[0.6, 0.2, 0.2])[0]
    reaction_delay = rng.randint(3, 8) if policy == 'late' else 0

    for t in range(EP_TICKS):
        # Factual policy (stochastic — varies by episode)
        ttc = compute_ttc(ego, ped)
        pi  = ped_intent(ped, cw['cx'], cw['cy'])
        ped_near_x = point_in_rect(ped.x, ped.y, cw['poly']) or pi

        if policy == 'cautious':
            if ped_near_x and ttc < 3.0:
                ego.brake = min(1.0, ego.brake + 0.15)
                ego.throttle = 0.0
            elif ego.speed < ego_spd0 * 0.9 and not ped_near_x:
                ego.throttle = 0.3; ego.brake = 0.0
            else:
                ego.throttle = 0.1
                ego.brake    = max(0.0, ego.brake - 0.05)
        elif policy == 'late':
            # Reacts like cautious but only after reaction_delay ticks
            if ped_near_x and ttc < 3.0 and t >= reaction_delay:
                ego.brake = min(1.0, ego.brake + 0.15)
                ego.throttle = 0.0
            else:
                ego.throttle = 0.15; ego.brake = max(0.0, ego.brake - 0.05)
        else:  # aggressive — maintains speed into crosswalk
            ego.throttle = 0.5; ego.brake = 0.0

        ego.step(TICK)
        ped.step(TICK)

        if not col:
            col = collision_check(ego, ped)

        pv = eval_predicates(ego, ped, cw, col)

        # Record fork at first PedIntent tick
        if branch_t_idx < 0 and pv['PedestrianIntentToCross']:
            branch_t_idx = t
            fork_ego_x   = ego.x
            fork_ego_vx  = ego.vx
            fork_ped_x   = ped.x
            fork_ped_y   = ped.y
            fork_ped_vy  = ped.vy

        factual_rows.append({h: pv[h] for h in PRED_HEADERS})
        raw_rows.append({
            'time_index': t,
            'timestamp':  round(t * TICK, 4),
            'ego_speed':  round(ego.speed, 4),
            'ped_speed':  round(abs(ped.current_vy), 4),
            'ego_x':      round(ego.x, 4),
            'ego_y':      round(ego.y, 4),
            'ped_x':      round(ped.x, 4),
            'ped_y':      round(ped.y, 4),
        })

        d = dist2d(ego.x, ego.y, ped.x, ped.y)
        # Episode end conditions
        if col or d > DISENG_RADIUS:
            break
        if ped.reached_target and not point_in_rect(ped.x, ped.y, cw['poly']):
            break

    if branch_t_idx < 0:
        branch_t_idx = 0

    # ---- Branch rollouts -------------------------------------------
    branch_data, branch_params = {}, {}
    for btype in ['brake', 'coast', 'accel']:
        rows, params = run_branch(
            ego_x0, ego_spd0,
            ped_spawn_x, ped_spawn_y, ped_spawn_vy,
            ped_speed, accel_ph, cw, btype,
            branch_t_idx, rng)
        branch_data[btype]   = rows
        branch_params[btype] = params

    # ---- Write outputs ---------------------------------------------
    ep_dir.mkdir(parents=True, exist_ok=True)
    write_csv(ep_dir / 'factual_trace.csv',   PRED_HEADERS,    factual_rows)
    write_csv(ep_dir / 'branch_brake.csv',    BRANCH_HEADERS,  branch_data['brake'])
    write_csv(ep_dir / 'branch_coast.csv',    BRANCH_HEADERS,  branch_data['coast'])
    write_csv(ep_dir / 'branch_accel.csv',    BRANCH_HEADERS,  branch_data['accel'])
    write_csv(ep_dir / 'raw_observables.csv', RAW_HEADERS,     raw_rows)

    meta = {
        'episode_id':            ep_id,
        'ego_policy':            policy,
        'map':                   'KinematicSim',
        'crosswalk_width':       round(cw_width, 3),
        'crosswalk_width_cat':   cw_width_cat(cw_width),
        'ped_category':          ped_cat,
        'pedestrian_speed':      round(ped_speed, 4),
        'pedestrian_speed_band': spd_band,
        'ego_initial_speed':     round(ego_spd0, 4),
        'spawn_distance':        round(spawn_d, 3),
        'map_weather':           weather,
        'branch_time_index':     branch_t_idx,
        'tick_duration':         TICK,
        'episode_ticks':         EP_TICKS,
        'branch_ticks':          BR_TICKS,
        'ped_entry_side':        entry,
        'ped_offset':            round(offset, 4),
        'ped_accel_phase':       round(accel_ph, 4),
        'branch_params':         branch_params,
    }
    with open(ep_dir / 'metadata.json', 'w') as f:
        json.dump(meta, f, indent=2)

    return True

# ----------------------------------------------------------------
# Dataset generator — entry point
# ----------------------------------------------------------------
def generate_dataset(root_dir, n_episodes=5_000, seed=42):
    from tqdm.notebook import tqdm
    rng  = random.Random(seed)
    root = Path(root_dir)
    root.mkdir(parents=True, exist_ok=True)

    # Resume: find highest complete episode id
    done = {int(d.name.split('_')[1])
            for d in root.glob('episode_*') if ep_done(d)}
    print(f'Already complete: {len(done)} episodes. Resuming ...')

    success  = len(done)
    attempt  = 0
    ep_id    = max(done, default=0) + 1

    pbar = tqdm(total=n_episodes, initial=success,
                desc='Episodes', unit='ep')
    while success < n_episodes:
        if ep_id in done:
            ep_id += 1
            continue
        attempt += 1
        ep_dir = root / f'episode_{ep_id:05d}'
        try:
            ok = run_episode(ep_id, ep_dir, rng)
        except Exception as e:
            print(f'[WARN] ep {ep_id}: {e}')
            ok = False
        if ok:
            success += 1
            pbar.update(1)
        else:
            try: ep_dir.rmdir()
            except: pass
        ep_id += 1

    pbar.close()
    print(f'Done: {success} episodes written to {root}')
    print(f'Attempt/success ratio: {attempt}/{success} '
          f'({100*success/max(attempt,1):.1f}%)')
    return root

