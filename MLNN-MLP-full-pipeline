# ----------------------------------------------------------------
# Training  (version F — formula head supervision)
# The formula head maps clause features to F2/F3 predictions.
# Loss directly supervises head outputs against formula targets.
# Clause weights learn discriminative features via backprop through head.
# ----------------------------------------------------------------
def masked_bce_loss(pred, target, mask):
    """Binary cross-entropy loss masked on active antecedent episodes.

    The masking was needed because of the independent variations in antecedent
       and consequent activations: F2 antecedents did not fire in ~91.4% of
       the episodes, resulting in near vacuous satisfaction.  Masking with
       a threshold of 0.3 seemed to balance this.
    """
    bce  = nn.functional.binary_cross_entropy(pred, target, reduction="none")
    denom = mask.sum() + 1e-6
    return (mask * bce).sum() / denom

def contrastive_branch_loss(T, model):
    _, C_nec, C_temp = model(T)
    brake_score = C_temp[:, 0, :].mean(dim=-1)
    accel_score = C_temp[:, 2, :].mean(dim=-1)
    return torch.clamp(accel_score - brake_score + 0.05, min=0.0).mean()

def train_mlnn(
    mlnn_tensor,
    n_clauses            = 8,
    epochs               = 300,
    lr                   = 3e-3,
    lambda_sparse        = 1e-4,
    lambda_cf            = 1.0,
    antecedent_threshold = 0.3,
    print_every          = 30,
):
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    print(f"Device: {device}")

    raw = torch.tensor(mlnn_tensor, dtype=torch.float32).to(device)
    raw = normalise_tensor(raw)
    T   = fuzzy_sigmoid(raw)
    E, B, Nt, P = T.shape
    print(f"Tensor: E={E} B={B} T={Nt} P={P}")

    IDX = {name: i for i, name in enumerate(PREDICATE_NAMES)}

    def pred_modal(idx, temporal_op=eventually, modal_op=necessarily):
        p = T[..., idx]
        p = temporal_op(p.unsqueeze(-1)).squeeze(-1)
        p = modal_op(p.unsqueeze(-1)).squeeze(-1)
        return p

    # For tracking/debug: compute fixed formula targets and masks once
    # Had help with this from Claude!
    with torch.no_grad():
        col     = pred_modal(IDX["Collision"],              eventually, possibly)
        accel   = pred_modal(IDX["EgoAccelerating"],        eventually, possibly)
        ped_x   = pred_modal(IDX["PedestrianInCrosswalk"], eventually, necessarily)
        ttc_low = pred_modal(IDX["TimeToCollision"],
                             lambda x: always(1.0 - x),    necessarily)
        stopped = pred_modal(IDX["EgoStopped"],            eventually, possibly)

        f2_tgt  = implication(col,           1.0 - accel).detach()
        f3_tgt  = implication(ped_x*ttc_low, stopped).detach()
        f2_mask = (col           > antecedent_threshold).float().detach()
        f3_mask = (ped_x*ttc_low > antecedent_threshold).float().detach()

        print(f"F2: mean={f2_tgt.mean():.4f}  std={f2_tgt.std():.4f}  "
              f"active={f2_mask.mean():.3f}")
        print(f"F3: mean={f3_tgt.mean():.4f}  std={f3_tgt.std():.4f}  "
              f"active={f3_mask.mean():.3f}")

        # Stack targets: (E, 2)  col 0=F2, col 1=F3
        f_targets = torch.stack([f2_tgt, f3_tgt], dim=1)
        f_masks   = torch.stack([f2_mask, f3_mask], dim=1)

    model     = MLNN(n_predicates=P, n_clauses=n_clauses, n_formulas=2).to(device)
    optimizer = optim.Adam(model.parameters(), lr=lr)
    scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=epochs)
    history   = []

    for epoch in range(1, epochs + 1):
        model.train()
        optimizer.zero_grad()

        f_pred, C_nec, C_temp = model(T)   # f_pred: (E,2)

        # Loss 1: supervised formula prediction (masked BCE)
        loss_f2 = masked_bce_loss(f_pred[:,0], f2_tgt, f2_mask)
        loss_f3 = masked_bce_loss(f_pred[:,1], f3_tgt, f3_mask)
        loss_sup = loss_f2 + 2.0 * loss_f3   # F3 weighted: more variance

        # Loss 2: contrastive branch
        cf_ramp  = min(1.0, epoch / 30.0)
        loss_cf  = contrastive_branch_loss(T, model)

        # Loss 3: sparsity on clause weights
        loss_sparse = torch.sum(torch.abs(torch.sigmoid(model.clause_weights)))

        loss = loss_sup + lambda_cf * cf_ramp * loss_cf + lambda_sparse * loss_sparse

        loss.backward()
        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
        optimizer.step()
        scheduler.step()

        with torch.no_grad():
            # Satisfaction from head predictions (not raw predicates)
            f2_sat_head = f_pred[:,0].mean().item()
            f3_sat_head = f_pred[:,1].mean().item()
            # Also track raw formula satisfaction for comparison
            f2_sat_raw  = implication(col, 1.0 - accel).mean().item()
            f3_sat_raw  = implication(ped_x * ttc_low, stopped).mean().item()
            # Head prediction accuracy
            f2_corr = torch.corrcoef(torch.stack([f_pred[:,0], f2_tgt]))[0,1].item()
            f3_corr = torch.corrcoef(torch.stack([f_pred[:,1], f3_tgt]))[0,1].item()

        history.append({
            "epoch":      epoch,
            "loss_f2":    loss_f2.item(),
            "loss_f3":    loss_f3.item(),
            "loss_cf":    loss_cf.item(),
            "loss_total": loss.item(),
            "f2_sat_head": f2_sat_head,
            "f3_sat_head": f3_sat_head,
            "f2_sat_raw":  f2_sat_raw,
            "f3_sat_raw":  f3_sat_raw,
            "f2_corr":     f2_corr,
            "f3_corr":     f3_corr,
            "f2_rate": f2_mask.mean().item(),
            "f3_rate": f3_mask.mean().item(),
        })

        if epoch % print_every == 0 or epoch == 1:
            print(f"Ep {epoch:4d}/{epochs} | "
                  f"F2_loss={loss_f2.item():.4f} F3_loss={loss_f3.item():.4f} | "
                  f"F2_corr={f2_corr:.3f} F3_corr={f3_corr:.3f} | "
                  f"cf={loss_cf.item():.4f}({cf_ramp:.1f})")

    print("Training complete.")
    return model, history

