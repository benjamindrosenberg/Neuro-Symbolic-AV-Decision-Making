# ----------------------------------------------------------------
# Rule / constraint extraction
# ----------------------------------------------------------------
def extract_rules(model, threshold=0.5, top_k=3):
    """
    Extract human-readable modal constraints from learned clause weights.

    A predicate 'participates' in a clause when its sigmoid weight > threshold.
    The extracted rule is interpreted as:
        □ F (P_i1 ∧ P_i2 ∧ ...) — necessarily, eventually the conjunction holds

    Parameters
    ----------
    model     : trained MLNN
    threshold : sigmoid weight above which a predicate is included in a clause
    top_k     : report only the top-k clauses by mean weight magnitude

    Returns
    -------
    rules : list of dicts with keys:
        clause_idx, predicates, weights, modal_form, strength
    """
    W = torch.sigmoid(model.clause_weights).detach().cpu().numpy()
    # W shape: (C, P)

    # Rank clauses by mean weight (most 'active' clauses first)
    clause_strength = W.mean(axis=1)               # (C,)
    ranked = np.argsort(clause_strength)[::-1]     # descending

    rules = []
    for rank, c in enumerate(ranked[:top_k]):
        participating = [(PREDICATE_NAMES[p], float(W[c, p]))
                         for p in range(W.shape[1])
                         if W[c, p] > threshold]
        participating.sort(key=lambda x: -x[1])  # sort by weight desc

        if not participating:
            continue

        pred_str = ' ∧ '.join(
            f'{name} ({w:.3f})' for name, w in participating
        )
        modal_form = f'□ F ({pred_str})'

        rules.append({
            'clause_idx':  int(c),
            'rank':        rank + 1,
            'predicates':  participating,
            'modal_form':  modal_form,
            'strength':    float(clause_strength[c]),
            'raw_weights': W[c].tolist(),
        })

    return rules


def print_rules(rules):
    """Pretty-print extracted modal constraints."""
    print('=' * 70)
    print('LEARNED MODAL SAFETY CONSTRAINTS')
    print('=' * 70)
    if not rules:
        print('No rules above threshold. Try lowering threshold in extract_rules().')
        return
    for r in rules:
        print(f"\nRule {r['rank']} (clause {r['clause_idx']}, "
              f"strength={r['strength']:.4f})")
        print(f"  Modal form : {r['modal_form']}")
        print(f"  Predicates : ")
        for name, w in r['predicates']:
            bar = '#' * int(w * 20)
            print(f"    {name:<30s} {w:.3f}  {bar}")
    print('=' * 70)


def satisfaction_report(model, T_fuzzy):
    """
    Note: Claude AI suggested inclusion of this after run D to
       assist in diagnosis.  My understanding was that loss and satisfaction
       were complementary, so this would be redundant.  But the MLNN needed
       raw targets, hence this "report."


    Compute per-formula satisfaction rates across all episodes.
    Useful for validating that the MLNN has learned meaningful constraints.
    """
    model.eval()
    with torch.no_grad():
        C_poss, C_nec, _ = model(T_fuzzy)

    IDX = {name: i for i, name in enumerate(PREDICATE_NAMES)}

    def pred_modal(idx, temporal_op=eventually, modal_op=necessarily):
        p = T_fuzzy[..., idx].unsqueeze(-1)
        return modal_op(temporal_op(p).squeeze(-1).unsqueeze(-1)).squeeze(-1)

    intent    = pred_modal(IDX['PedestrianIntentToCross'], eventually, necessarily)
    brake     = pred_modal(IDX['EgoBraking'],              eventually, possibly)
    collision = pred_modal(IDX['Collision'],               eventually, necessarily)
    accel     = pred_modal(IDX['EgoAccelerating'],         eventually, possibly)
    ped_in_x  = pred_modal(IDX['PedestrianInCrosswalk'],  eventually, necessarily)
    ttc_low   = pred_modal(IDX['TimeToCollision'],
                           lambda x: eventually(1.0 - x), necessarily)
    stopped   = pred_modal(IDX['EgoStopped'],              eventually, possibly)

    f1 = implication(intent, brake)
    f2 = implication(collision, 1.0 - accel)
    f3 = implication(ped_in_x * ttc_low, stopped)

    print('\nSATISFACTION REPORT')
    print('-' * 50)
    formulas = [
        ('F1: □(PedIntent → ◊Brake)',                f1),
        ('F2: □(Collision → ¬◊Accel)',               f2),
        ('F3: □(PedInX ∧ LowTTC → ◊Stopped)',        f3),
    ]
    for name, val in formulas:
        sat = val.mean().item()
        pct = val.gt(0.5).float().mean().item() * 100
        print(f'  {name:<40s}  mean={sat:.4f}  >0.5: {pct:.1f}%')
    print('-' * 50)

